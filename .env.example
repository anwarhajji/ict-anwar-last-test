# Clé de chiffrement pour sécuriser les API secrets Binance (Doit être une chaîne aléatoire de 32 caractères pour AES-256)
ENCRYPTION_KEY=

# Token global du Bot Telegram pour envoyer les webhooks
TELEGRAM_GLOBAL_BOT_TOKEN=

# API Binance (Optionnel, si besoin d'un fallback global)
VITE_BINANCE_API_KEY=
VITE_BINANCE_API_SECRET=

# Email du Super Admin (Donne tous les droits)
VITE_SUPER_ADMIN_EMAIL=anwar.hajji@gmail.com

# Configuration Firebase (Copiez les valeurs de firebase-applet-config.json)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
# ID de la base de données Firestore (si différent de '(default)')
VITE_FIREBASE_FIRESTORE_DATABASE_ID=
